<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F9FA"
    tools:context=".MainActivity">

    <!-- Título Principal -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:text="Calculadora"
        android:textAlignment="center"
        android:textColor="#2D3436"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <!-- Contenedor de Inputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/etNumero1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Primer número"
            android:inputType="numberDecimal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:color/transparent"
            android:layout_marginBottom="8dp"
            android:textSize="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNumero2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Segundo número"
            android:inputType="numberDecimal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:color/transparent"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Botones de Operación -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnSumar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="Sumar"
            android:textAllCaps="false"
            android:backgroundTint="#0984E3"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnRestar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="Restar"
            android:textAllCaps="false"
            android:backgroundTint="#D63031"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnMultiplicar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="Multiplicar"
            android:textAllCaps="false"
            android:backgroundTint="#F1C40F"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnDividir"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="Dividir"
            android:textAllCaps="false"
            android:backgroundTint="#00B894"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:cornerRadius="12dp" />
    </GridLayout>

    <!-- Sección de Resultado -->
    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resultado: -"
        android:textAlignment="center"
        android:textColor="#2D3436"
        android:textSize="24sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:background="#E1F5FE" />

</LinearLayout>
